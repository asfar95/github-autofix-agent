# GitHub
GITHUB_TOKEN=your_github_personal_access_token   # needs: repo + issues + pull_requests scope
GITHUB_WEBHOOK_SECRET=your_webhook_secret         # leave blank to skip signature verification

# AI — works with any OpenAI-compatible provider
#
# Provider    | AI_MODEL                        | AI_BASE_URL                                          | Free tier
# ------------|----------------------------------|------------------------------------------------------|----------
# Groq        | llama-3.3-70b-versatile          | https://api.groq.com/openai/v1                       | 100k TPD
# Groq (fast) | llama-3.1-8b-instant             | https://api.groq.com/openai/v1                       | 500k TPD, 6k TPM
# Gemini      | gemini-2.0-flash                 | https://generativelanguage.googleapis.com/v1beta/openai/ | 1M TPD
# OpenAI      | gpt-4o-mini                      | https://api.openai.com/v1                            | paid
# Anthropic   | claude-haiku-4-5-20251001        | (use Anthropic SDK separately)                       | paid
#
AI_API_KEY=your_api_key
AI_MODEL=llama-3.3-70b-versatile
AI_BASE_URL=https://api.groq.com/openai/v1

# Server
PORT=3003

# Pipeline — delay (ms) before autofix starts, to let the triage agent finish first.
# Only needed if both agents share the same API key/quota. Set to 0 with separate keys.
# Note: autofix → review-fix sequencing is handled by an in-memory lock, not a delay.
AUTOFIX_STARTUP_DELAY=0

# Agent tuning
AI_MAX_TOKENS=1500       # max output tokens per LLM call — keep input+output under model TPM limit
AGENT_MAX_ITERATIONS=12  # hard stop on the agent loop; a focused fix should finish in 8–10
AGENT_MAX_RETRIES=3      # retries on transient 429/503 errors before giving up
