# GitHub
GITHUB_TOKEN=your_github_personal_access_token   # needs: repo + issues + pull_requests scope
GITHUB_WEBHOOK_SECRET=your_webhook_secret         # random string, must match GitHub webhook config

# AI — works with any OpenAI-compatible provider
# Groq (free):   console.groq.com              model: llama-3.3-70b-versatile  base: https://api.groq.com/openai/v1
# Gemini (free): aistudio.google.com            model: gemini-2.0-flash         base: https://generativelanguage.googleapis.com/v1beta/openai/
# OpenAI:        platform.openai.com            model: gpt-4o-mini              base: (leave blank)
AI_API_KEY=your_api_key
AI_MODEL=llama-3.3-70b-versatile
# AI_BASE_URL=https://api.groq.com/openai/v1   # defaults to Groq if not set

# Server
PORT=3003
